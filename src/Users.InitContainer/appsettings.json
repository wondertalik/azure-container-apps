{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Azure.Cosmos": "Warning"
    }
  },
  "UsersDropDatabaseIfExists": false,
  "Users": {
    "UsersInfrastructureCosmosDbOptions": {
      "DatabaseId": "users-db",
      "Throughput": 400,
      "UseIntegratedCache": false,
      "IgnoreSslCertificateValidation": false
    }
  },
  "SeederOptions": {
    "TenantsSeed": false,
    "UsersSeed": false,
    "SeedDataFilePath": "/app/seed-data"
  }
}
